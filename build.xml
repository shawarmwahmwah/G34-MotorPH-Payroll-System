<?xml version="1.0" encoding="UTF-8"?>
<project name="G34-MotorPH-Payroll-System" default="run" basedir=".">
    <description>Ant build for G34 MotorPH Payroll System</description>

    <property name="src.dir" value="src"/>
    <property name="build.dir" value="build/classes"/>
    <property name="main.class" value="motorph.ui.AppLauncher"/>

    <target name="clean">
        <delete dir="build"/>
        <delete dir="dist"/>
    </target>

    <target name="init">
        <mkdir dir="${build.dir}"/>
    </target>

    <target name="compile" depends="init">
        <javac srcdir="${src.dir}" destdir="${build.dir}" includeantruntime="false" encoding="UTF-8"/>
    </target>

    <target name="run" depends="compile">
        <java classname="${main.class}" fork="true">
            <classpath>
                <pathelement path="${build.dir}"/>
            </classpath>
        </java>
    </target>
</project>